{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "@openfinance/shared": ["../shared/src/index.ts"],
      "@openfinance/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}

{
  "name": "@openfinance-sh/mcp",
  "version": "0.1.8",
  "type": "module",
  "mcpName": "io.github.Openfinanceorg/openfinance",
  "description": "Connect your financial accounts to view balances, search transactions, and get spending insights.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Openfinanceorg/openfinance-app",
    "directory": "mcp-server"
  },
  "license": "MIT",
  "bin": {
    "openfinance-mcp": "./build/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node build/index.js",
    "bundle": "pnpm build && mcpb pack . openfinance.mcpb",
    "prepack": "pnpm run bundle"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "files": [
    "build",
    "manifest.json",
    "openfinance.mcpb",
    "server.json"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@anthropic-ai/mcpb": "^2.1.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}

{
  "name": "@openfinance/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "openfinance-mcp": "./build/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean --outDir build",
    "start": "node build/index.js",
    "bundle": "pnpm build && mcpb pack . openfinance.mcpb"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openfinance/shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "files": ["build", "manifest.json", "openfinance.mcpb"],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@anthropic-ai/mcpb": "^2.1.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
